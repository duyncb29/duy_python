# Môi trường chạy ứng dụng (development, staging, production)
APP_ENV=development

# API Key giả lập cho LLM (Không được để trống khi chạy thực tế)
LLM_API_KEY=your_mock_api_key_here

# Model LLM sử dụng (mặc định: gpt-4o)
LLM_MODEL=gpt-4o

# Thời gian timeout cho mỗi yêu cầu gọi LLM (giây)
TIMEOUT_SECONDS=30
